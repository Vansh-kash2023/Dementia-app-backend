# Flask runtime
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
HOST=127.0.0.1
PORT=10000

# Comma-separated origins that can call this API.
# Required in production. Example: https://yourapp.com,https://www.yourapp.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# App security
# Required. Use a long random string in real deployments.
JWT_SECRET_KEY=change-this-jwt-secret

# Database
# Required.
# Supabase / PostgreSQL SQLAlchemy URI
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://postgres:YOUR_URL_ENCODED_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SQLALCHEMY_TRACK_MODIFICATIONS=false

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=dementia-app

# AI integration
# Required. Get from Google AI Studio / Gemini.
GEMINI_API_KEY=replace-with-your-gemini-api-key
